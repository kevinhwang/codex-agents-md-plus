{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/src/hook.py",
            "statusMessage": "Loading AGENTS local overlays"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/src/hook.py",
            "statusMessage": "Loading AGENTS local overlays"
          }
        ]
      }
    ]
  }
}
